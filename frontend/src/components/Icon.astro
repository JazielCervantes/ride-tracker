---
import { ICON_PATHS } from '../lib/icons.js';
const { name, size = 18, class: className } = Astro.props;
const path = ICON_PATHS[name] || '';
---
<svg
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="2"
  stroke-linecap="round"
  stroke-linejoin="round"
  class:list={["rt-icon", className]}
  aria-hidden="true"
  set:html={path}
/>
